<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Declarar que es una app de TV -->
    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />

    <!-- No requiere pantalla táctil -->
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".SmartHealthTVApplication"
        android:theme="@style/Theme.SmartHealthTV"
        android:banner="@drawable/banner_tv"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="SmartHealth TV"
        android:supportsRtl="true">

        <activity
            android:name=".TVActivity"
            android:exported="true"
            android:label="SmartHealth TV">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
        </activity>

        <meta-data
            android:name="com.google.android.gms.cast.framework.OPTIONS_PROVIDER_CLASS_NAME"
            android:value="mx.utng.smarthealthmonitor.tv.TvCastOptionsProvider" />

        <service
            android:name=".TvWearListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:scheme="wear"
                    android:pathPrefix="/smarthealthmonitor" />
            </intent-filter>
        </service>
    </application>
</manifest>
